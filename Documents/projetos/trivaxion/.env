# Application Settings
APP_NAME=Trivaxion
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Database Configuration
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/trivaxion
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=trivaxion

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json

# Scraper Configuration
SCRAPER_TIMEOUT_SECONDS=30
SCRAPER_MAX_RETRIES=3
SCRAPER_RETRY_DELAY_SECONDS=2

# External URLs
RECEITA_FEDERAL_BASE_URL=https://www.receitafederal.gov.br
CERTIDAO_TRABALHISTA_URL=https://www.tst.jus.br/certidao1

# Plan Limits
MAX_ANALYSES_PER_MONTH_FREE=100
MAX_ANALYSES_PER_MONTH_STARTER=500
MAX_ANALYSES_PER_MONTH_PROFESSIONAL=2000
MAX_ANALYSES_PER_MONTH_ENTERPRISE=99999

# Playwright Configuration (for scrapers)
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_HEADLESS=true

# Optional: Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_TLS=true

# Optional: Monitoring
# SENTRY_DSN=your-sentry-dsn

# Optional: Analytics
# GOOGLE_ANALYTICS_ID=your-ga-id

# Production-only settings
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem
